{
  "version": 1,
  "command": "pyramid",
  "imports_base": [
    "EngineBuilder",
    "EngineConfig",
    "FsSink",
    "Layout",
    "PyramidPlanner",
    "TileFormat",
    "decode_file"
  ],
  "slot_order": [
    "tracing-init",
    "load-source",
    "planner",
    "memory-limit",
    "geo",
    "sink",
    "engine-config",
    "engine-builder",
    "finish"
  ],
  "slots": {
    "tracing-init": {
      "imports_when_active": [],
      "lines": [
        "tracing_subscriber::fmt()",
        "    .with_env_filter(EnvFilter::new(\"{trace-level}\"))",
        "    .init();"
      ],
      "gated_by": [
        "trace-level"
      ]
    },
    "load-source": {
      "imports_when_active": [],
      "lines": [
        "let raster = if input.extension().and_then(|e| e.to_str()) == Some(\"pdf\") {",
        "    libviprs::extract_page_image(&input, {page})?",
        "} else {",
        "    decode_file(&input)?",
        "};"
      ]
    },
    "planner": {
      "imports_when_active": [],
      "lines": [
        "let planner = PyramidPlanner::new(",
        "    raster.width(),",
        "    raster.height(),",
        "    {tile-size},",
        "    {overlap},",
        "    Layout::{layout},",
        ")?;",
        "let plan = planner.plan();"
      ]
    },
    "memory-limit": {
      "imports_when_active": [],
      "lines": [
        "let limit = {memory-limit}u64 * 1024 * 1024;",
        "if planner.estimate_peak_memory() > limit {",
        "    return Err(\"estimated peak memory exceeds --memory-limit\".into());",
        "}"
      ],
      "gated_by": [
        "memory-limit"
      ]
    },
    "geo": {
      "imports_when_active": [
        "GeoCoord",
        "GeoTransform"
      ],
      "lines": [
        "let _geo = GeoTransform::from_origin_and_scale(",
        "    GeoCoord::new({geo-origin}),",
        "    {geo-scale},",
        ");"
      ],
      "gated_by": [
        "geo-origin",
        "geo-scale"
      ]
    },
    "sink": {
      "imports_when_active": [],
      "lines": [
        "let sink = FsSink::new(&output, plan.clone())",
        "    .with_format(TileFormat::{format});"
      ]
    },
    "engine-config": {
      "imports_when_active": [],
      "lines": [
        "let config = EngineConfig::default();"
      ]
    },
    "engine-builder": {
      "imports_when_active": [],
      "lines": [
        "let result = EngineBuilder::new(&raster, plan.clone(), &sink)",
        "    .with_config(config)",
        "    .run()?;"
      ]
    },
    "finish": {
      "imports_when_active": [],
      "lines": [
        "eprintln!(",
        "    \"Done: {{}} tiles, {{}} levels, peak {{:.1}} MB\",",
        "    result.tiles_produced,",
        "    result.levels_processed,",
        "    result.peak_memory_bytes as f64 / (1024.0 * 1024.0),",
        ");"
      ]
    }
  },
